    "y_q1 = np.percentile(y_raw, 25)\n",
    "y_q3 = np.percentile(y_raw, 75)\n",
    "y_ric = y_q3 - y_q1\n",
    "\n",
    "# Aplicar normalización\n",
    "X_robust = (X_raw - X_median) / X_ric\n",
    "y_robust = (y_raw - y_median) / y_ric\n",
